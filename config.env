# =============================================================================
# MLX Server Configuration
# Edit this file to change models or server settings.
# Restart the service after changes: make restart
# =============================================================================

# Model to serve — must be an mlx-community quantized model on HuggingFace
# 128GB RAM options:
#   mlx-community/Meta-Llama-3.1-70B-Instruct-4bit   (~38GB, recommended)
#   mlx-community/Llama-3.3-70B-Instruct-4bit         (~38GB, newer)
#   mlx-community/Meta-Llama-3.1-8B-Instruct-4bit     (~5GB, fast/light)
#   mlx-community/Mistral-7B-Instruct-v0.3-4bit        (~4GB, fast/light)
#   mlx-community/Qwen2.5-Coder-7B-Instruct-4bit       (~4GB, code tasks)
MLX_MODEL=mlx-community/Meta-Llama-3.1-70B-Instruct-4bit

# Server bind address — 0.0.0.0 allows LiteLLM and local network access
MLX_HOST=0.0.0.0

# Port the MLX server listens on
MLX_PORT=8080

# Maximum tokens per response
MLX_MAX_TOKENS=8192
